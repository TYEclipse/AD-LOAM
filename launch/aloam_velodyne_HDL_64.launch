<launch>

<param name="lidar_type" type="string" value="HDL-64E" />

<!-- if 1, do mapping 10 Hz, if 2, do mapping 5 Hz. Suggest to use 1, it will adjust frequence automaticlly -->
<param name="mapping_skip_frame" type="int" value="1" />

<!-- remove too closed points -->
<param name="minimum_range" type="double" value="1.33"/>


<param name="mapping_line_resolution" type="double" value="0.12"/>
<param name="mapping_plane_resolution" type="double" value="0.47"/>

<param name="max_object_speed" type="double" value="0.2"/>
<param name="max_class_dist" type="double" value="0.2"/>

<param name="cluster_min_pts" type="int" value="800"/>
<param name="cluster_max_pts" type="int" value="8192"/>
<param name="cluster_min_size" type="double" value="0.2"/>
<param name="cluster_max_size" type="double" value="20.0"/>

<param name="cluster_tolerane" type="double" value="0.4"/>
<param name="cluster_lambda" type="double" value="0.8"/>

<param name="auto_mapping" type="bool" value="false"/>
<param name="auto_mapping_time" type="double" value="1000.0"/>
<param name="remove_enable" type="bool" value="true"/>

<param name="lidar_min_z" type="double" value="-1.74"/>
<param name="lidar_max_z" type="double" value="3.48"/>



<node pkg="aloam_velodyne" type="ascanRegistration" name="ascanRegistration" output="screen" />

<node pkg="aloam_velodyne" type="alaserOdometry" name="alaserOdometry" output="screen" />

<node pkg="aloam_velodyne" type="alaserMapping" name="alaserMapping" output="screen" />

<arg name="rviz" default="true" />
<group if="$(arg rviz)">
<node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find aloam_velodyne)/rviz_cfg/aloam_velodyne.rviz" />
</group>

</launch>
